<?xml version="1.0" encoding="utf-8"?> 
<AutoVisualizer xmlns="http://schemas.microsoft.com/vstudio/debugger/natvis/2010">

<!--
	Reference Document 
	https://msdn.microsoft.com/en-us/library/jj620914.aspx
	
	Expression[,<FormatSpecifier> ]
	https://msdn.microsoft.com/en-us/library/windows/hardware/dn936815(v=vs.85).aspx
-->
	<Type Name="ax::RenderObject">
		<DisplayString>name={_name}</DisplayString>
		<!--
		<Expand>
			<Item Name="name">_name</Item>
			<Item Name="debugName">_debugName</Item>
		</Expand>
		-->
	</Type>

	<Type Name="ax::Texture2D_Backend">
		<DisplayString>name={_name} assetPath={_assetPath}</DisplayString>
		<!--
		<Expand>
			<Item Name="name">_name</Item>
			<Item Name="debugName">_debugName</Item>
			<Item Name="assetPath">_assetPath</Item>
			<Item Name="slotId">objectSlot._slotId</Item>
		</Expand>
		-->
	</Type>

	<Type Name="ax::ShaderParamSpace_Backend">
		<DisplayString>[{_bindSpace}] {*_shaderPass}</DisplayString>
		<!--
		<Expand>
			<Item Name="name">_name</Item>
			<Item Name="debugName">_debugName</Item>
			<Item Name="bindSpace">_bindSpace</Item>
			<Item Name="shaderPass">_shaderPass</Item>
			<Item Name="assetPath">_shaderPass->_shader->_assetPath</Item>
		</Expand>
		-->
	</Type>

	<Type Name="ax::ShaderPass_Backend">
		<DisplayString>{_name} {_shader->_assetPath}</DisplayString>
		<!--
		<Expand>
			<Item Name="name">_name</Item>
			<Item Name="debugName">_debugName</Item>
			<Item Name="shaderParamSpaces">_shaderParamSpaces</Item>
			<Item Name="shader">_shader</Item>
			<Item Name="assetPath">_shader->_assetPath</Item>
		</Expand>
		-->
	</Type>

	<Type Name="ax::Shader">
		<DisplayString>{_assetPath}</DisplayString>
		<!--
		<Expand>
			<Item Name="name">_name</Item>
			<Item Name="debugName">_debugName</Item>
			<Item Name="assetPath">_assetPath</Item>
		</Expand>
		-->
	</Type>

	<Type Name="ax::MaterialParamSpace_Backend">
		<DisplayString>BindSpace::{_shaderParamSpace._p->_bindSpace}[{*_materialPass}]</DisplayString>
		<!--
		<Expand>
			<Item Name="name">_name</Item>
			<Item Name="debugName">_debugName</Item>
			<Item Name="bindSpace">_shaderParamSpace._p->_bindSpace</Item>
			<Item Name="paramSpace">_shaderParamSpace._p</Item>
			<Item Name="materialPass">_materialPass</Item>
		</Expand>
		-->
	</Type>

	<Type Name="ax::MaterialPass_Backend">
		<DisplayString>MaterialPass-{*_shaderPass}</DisplayString>
		<!--
		<Expand>
			<Item Name="name">_name</Item>
			<Item Name="debugName">_debugName</Item>
			<Item Name="paramSpaces">_materialParamSpaces</Item>
			<Item Name="material">_material</Item>
			<Item Name="shaderPass">_shaderPass</Item>
		</Expand>
		-->
	</Type>

	<Type Name="ax::Material_Backend">
		<DisplayString>{*_shader_backend._p}</DisplayString>
		<!--
		<Expand>
			<Item Name="name">_name</Item>
			<Item Name="debugName">_debugName</Item>
			<Item Name="shader">_shader_backend</Item>
		</Expand>
		-->
	</Type>


</AutoVisualizer>