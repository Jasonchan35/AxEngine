<?xml version="1.0" encoding="utf-8"?> 
<AutoVisualizer xmlns="http://schemas.microsoft.com/vstudio/debugger/natvis/2010"> 	

<!--
	Reference Document 
	https://msdn.microsoft.com/en-us/library/jj620914.aspx
	
	Expression[,<FormatSpecifier> ]
	https://msdn.microsoft.com/en-us/library/windows/hardware/dn936815(v=vs.85).aspx
-->
	<!-- ax::Tuple1_<*,*> -->
	<Type Name="ax::Vec1_&lt;*,*&gt;">
		<DisplayString>x={x}</DisplayString>
	</Type>

	<!-- ax::Tuple2_<*,*> -->
	<Type Name="ax::Tuple2_&lt;*,*&gt;">
		<DisplayString>x={x}, y={y}</DisplayString>
	</Type>

	<!-- ax::Tuple3_<*,*> -->
	<Type Name="ax::Tuple3_&lt;*,*&gt;">
		<DisplayString>x={x}, y={y}, z={z}</DisplayString>
	</Type>

	<!-- ax::Tuple4_<*,*> -->
	<Type Name="ax::Tuple4_&lt;*,*&gt;">
		<DisplayString>x={x}, y={y}, z={z}, w={w}</DisplayString>
	</Type>

	<!-- Margin2_<T> -->
	<Type Name="ax::Margin2_&lt;*&gt;">
		<DisplayString>top={top}, right={right}, bottom={bottom}, left={left}</DisplayString>
	</Type>
	<!-- Rect2<T> -->
	<Type Name="ax::Rect2_&lt;*&gt;">
		<DisplayString>x={x}, y={y}, w={w}, h={h}</DisplayString>
	</Type>
	<!-- ColorR<T> -->
	<Type Name="ax::ColorR_&lt;*&gt;">
		<DisplayString>r={r}</DisplayString>
	</Type>

	<!-- ColorRG_<T> -->
	<Type Name="ax::ColorRGBA_&lt;*&gt;">
		<DisplayString>r={r}, g={g}</DisplayString>
	</Type>

	<!-- ColorRGB_<T> -->
	<Type Name="ax::ColorRGBA_&lt;*&gt;">
		<DisplayString>r={r}, g={g}, b={b}</DisplayString>
	</Type>

	<!-- ColorRGBA_<T> -->
	<Type Name="ax::ColorRGBA_&lt;*&gt;">
		<DisplayString>r={r}, g={g}, b={b}, a={a}</DisplayString>
	</Type>

	<Type Name="ax::Debug::Natvis_Hex::L4">
		<DisplayString Condition="((c &amp; 0x0f) == 0x00)">0</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x01)">1</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x02)">2</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x03)">3</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x04)">4</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x05)">5</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x06)">6</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x07)">7</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x08)">8</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x09)">9</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0a)">A</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0b)">B</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0c)">C</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0d)">D</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0e)">E</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0f)">F</DisplayString>
	</Type>
 
	<Type Name="ax::Debug::Natvis_Hex::H4">
		<DisplayString Condition="((c >> 4) == 0x00)">0</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x01)">1</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x02)">2</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x03)">3</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x04)">4</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x05)">5</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x06)">6</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x07)">7</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x08)">8</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x09)">9</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0a)">A</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0b)">B</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0c)">C</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0d)">D</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0e)">E</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0f)">F</DisplayString>
	</Type>

	
	<Type Name="ax::Debug::Natvis_Hex::l4">
		<DisplayString Condition="((c &amp; 0x0f) == 0x00)">0</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x01)">1</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x02)">2</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x03)">3</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x04)">4</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x05)">5</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x06)">6</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x07)">7</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x08)">8</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x09)">9</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0a)">a</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0b)">b</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0c)">c</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0d)">d</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0e)">e</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0f)">f</DisplayString>
	</Type>

	<Type Name="ax::Debug::Natvis_Hex::h4">
		<DisplayString Condition="((c >> 4) == 0x00)">0</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x01)">1</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x02)">2</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x03)">3</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x04)">4</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x05)">5</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x06)">6</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x07)">7</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x08)">8</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x09)">9</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0a)">a</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0b)">b</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0c)">c</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0d)">d</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0e)">e</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0f)">f</DisplayString>
	</Type>

	<Type Name="ax::Uuid;">
		<DisplayString>
			[Uuid]
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 0 )}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 0 )}
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 1 )}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 1 )}
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 2 )}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 2 )}
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 3 )}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 3 )}-
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 4 )}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 4 )}
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 5 )}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 5 )}-
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 6 )}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 6 )}
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 7 )}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 7 )}-
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 8 )}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 8 )}
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 9 )}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 9 )}-
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 10)}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 10)}
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 11)}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 11)}
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 12)}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 12)}
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 13)}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 13)}
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 14)}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 14)}
			{*(ax::Debug::Natvis_Hex::h4*)((char*)this + 15)}{*(ax::Debug::Natvis_Hex::l4*)((char*)this + 15)}
		</DisplayString>
		<Expand>
			<Item Name="first ">value.first,x</Item>
			<Item Name="second">value.second,x</Item>
		</Expand>
	</Type>

	<!-- ax::AxCore::AtomicInt_<T> -->
	<Type Name="ax::AxCore::AtomicInt_&lt;*&gt;">
		<DisplayString>{_v}</DisplayString>
		<Expand>
			<ExpandedItem>_v</ExpandedItem>
		</Expand>
	</Type>

	<!-- ax::AxCore::PtrBase<T> -->
	<Type Name="ax::AxCore::PtrBase&lt;*&gt;">
		<DisplayString>{(void*)_p}</DisplayString>
		<Expand>
			<Item Name="_p">_p</Item>
		</Expand>
	</Type>

	<!-- ax::SPtr<T> -->
	<Type Name="ax::SPtr&lt;*&gt;">
		<DisplayString Condition="_p != nullptr">SPtr refCount={_p->_refCount}</DisplayString>
		<DisplayString>SPtr is NULL</DisplayString>
		<Expand>
			<Item Name="_p">_p</Item>
		</Expand>
	</Type>

	<Type Name="ax::JsonReader">
		<DisplayString>line={_lineNumber} token={_token} </DisplayString>
	</Type>

	<!-- ax::MutSpan<*> -->
	<Type Name="ax::MutSpan&lt;*&gt;">
		<DisplayString>Span size={_size}</DisplayString>
		<Expand> 
			<Item Name="_data">_data</Item>
			<Item Name="_size">_size</Item> 
			<ArrayItems> 
			  <Size>_size</Size> 
			  <ValuePointer>_data</ValuePointer> 
			</ArrayItems> 
		</Expand> 	
	</Type>
	
	<!-- FixedArray<*,*> -->
	<Type Name="ax::FixedArray&lt;*,*&gt;">
		<DisplayString>size={_size}</DisplayString>
		<Expand>
			<Item Name="_data">_data</Item>
			<Item Name="_size">kSize</Item>
			<ArrayItems>
				<Size>kSize</Size>
				<ValuePointer>_data</ValuePointer>
			</ArrayItems>
		</Expand>
	</Type>

	<!-- ax::IArayStorage<*>::Storage -->
	<Type Name="ax::IArrayStorage&lt;*&gt;::Storage">
		<DisplayString Condition="!kSmallBufferOptimization">
			size={_normal._size} capacity={_normal._capacity}
		</DisplayString>
		<DisplayString Condition="_small._capacity &amp; 0x80">
			size={(int)_small._size} small-capacity={SmallStorage::kExtraCapacity + (_small._capacity &amp; 0x7F)}
		</DisplayString>
		<DisplayString Condition="kSmallBufferOptimization &amp;&amp; ~_small._capacity &amp; 0x80">
			size={_normal._size} normal-capacity={
			(
				  (((uint8_t*)&amp;_normal._capacity)[0] &lt;&lt; 56)
				+ (((uint8_t*)&amp;_normal._capacity)[1] &lt;&lt; 48)
				+ (((uint8_t*)&amp;_normal._capacity)[2] &lt;&lt; 40)
				+ (((uint8_t*)&amp;_normal._capacity)[3] &lt;&lt; 32)
				+ (((uint8_t*)&amp;_normal._capacity)[4] &lt;&lt; 24)
				+ (((uint8_t*)&amp;_normal._capacity)[5] &lt;&lt; 16)
				+ (((uint8_t*)&amp;_normal._capacity)[6] &lt;&lt; 8 )
				+ (((uint8_t*)&amp;_normal._capacity)[7]            )
			)}
		</DisplayString>
		<Expand>
			<Item Name="data" Condition=" _small._capacity &amp; 0x80">&amp;_small._data[0]</Item>
			<Item Name="data" Condition="~_small._capacity &amp; 0x80">_normal._data</Item>

			<Item Name="size" Condition=" _small._capacity &amp; 0x80">_small._size</Item>
			<Item Name="size" Condition="~_small._capacity &amp; 0x80">_normal._size</Item>

			<Item Name="capacity" Condition="!kSmallBufferOptimization">_normal._capacity</Item>
			<Item Name="capacity" Condition=" _small._capacity &amp; 0x80">SmallStorage::kExtraCapacity + (_small._capacity &amp; 0x7F)</Item>
			<Item Name="capacity" Condition="kSmallBufferOptimization &amp;&amp; ~_small._capacity &amp; 0x80">
				( (((uint8_t*)&amp;_normal._capacity)[0] &lt;&lt; 56)
				+ (((uint8_t*)&amp;_normal._capacity)[1] &lt;&lt; 48)
				+ (((uint8_t*)&amp;_normal._capacity)[2] &lt;&lt; 40)
				+ (((uint8_t*)&amp;_normal._capacity)[3] &lt;&lt; 32)
				+ (((uint8_t*)&amp;_normal._capacity)[4] &lt;&lt; 24)
				+ (((uint8_t*)&amp;_normal._capacity)[5] &lt;&lt; 16)
				+ (((uint8_t*)&amp;_normal._capacity)[6] &lt;&lt; 8 )
				+ (((uint8_t*)&amp;_normal._capacity)[7]            ))
			</Item>
			<Item Name="SmallStorage::kExtraCapacity">SmallStorage::kExtraCapacity</Item>
		</Expand>
	</Type>

	<!-- ax::IArray<*> -->
	<Type Name="ax::IArray&lt;*&gt;">
		<DisplayString Condition="!kSmallBufferOptimization">
			size={_storage._normal._size} cap={_storage._normal._capacity} data={_storage._normal._data, [_storage._normal._size]na}
		</DisplayString>
		<DisplayString Condition="_storage._small._capacity &amp; 0x80">
			size={(int)_storage._small._size} cap={Base::SmallStorage::kExtraCapacity}+{_storage._small._capacity &amp; 0x7F} data={&amp;_storage._small._data[0], [_storage._small._size]na}
		</DisplayString>
		<DisplayString Condition="kSmallBufferOptimization &amp;&amp; ~_storage._small._capacity &amp; 0x80">
			size={_storage._normal._size} cap={
				( (((uint8_t*)&amp;_storage._normal._capacity)[0] &lt;&lt; 56)
				+ (((uint8_t*)&amp;_storage._normal._capacity)[1] &lt;&lt; 48)
				+ (((uint8_t*)&amp;_storage._normal._capacity)[2] &lt;&lt; 40)
				+ (((uint8_t*)&amp;_storage._normal._capacity)[3] &lt;&lt; 32)
				+ (((uint8_t*)&amp;_storage._normal._capacity)[4] &lt;&lt; 24)
				+ (((uint8_t*)&amp;_storage._normal._capacity)[5] &lt;&lt; 16)
				+ (((uint8_t*)&amp;_storage._normal._capacity)[6] &lt;&lt; 8 )
				+ (((uint8_t*)&amp;_storage._normal._capacity)[7]            ))
			} {_storage._normal._data, [_storage._normal._size]na}
		</DisplayString>
		<Expand>
			<Item Name="_storage">_storage</Item>
			<Synthetic Name="Elements">
				<DisplayString> </DisplayString>
				<Expand>
					<ArrayItems Condition="_storage._small._capacity &amp; 0x80">
						<Size>_storage._small._size</Size>
						<ValuePointer>&amp;_storage._small._data[0]</ValuePointer>
					</ArrayItems>

					<ArrayItems Condition="~_storage._small._capacity &amp; 0x80">
						<Size>_storage._normal._size</Size>
						<ValuePointer>_storage._normal._data</ValuePointer>
					</ArrayItems>
				</Expand>
			</Synthetic>
		</Expand>
	</Type>

	<!-- MutStrView_<*> -->
	<Type Name="ax::MutStrView_&lt;*&gt;">
		<DisplayString>size={_size} {_data, [_size]na}</DisplayString>
		<StringView>_data, [_size]na</StringView>
		<Expand>
			<Item Name="size">_size</Item>
		</Expand>
	</Type>

	<!-- ax::IString_<*> -->
	<Type Name="ax::IString_&lt;*&gt;">
		<DisplayString Condition="_storage._small._capacity &amp; 0x80">
			size={(int)_storage._small._size} cap={Base::SmallStorage::kExtraCapacity}+{_storage._small._capacity &amp; 0x7F} {&amp;_storage._small._data[0], [_storage._small._size]na}
		</DisplayString>
		<DisplayString Condition="~_storage._small._capacity &amp; 0x80">
			size={_storage._normal._size} cap={_storage._normal._capacity} {_storage._normal._data, [_storage._normal._size]na}
		</DisplayString>

		<StringView  Condition="_storage._small._capacity &amp; 0x80">
			&amp;_storage._small._data[0], [_storage._small._size]na
		</StringView>
		<StringView  Condition="~_storage._small._capacity &amp; 0x80">
			_storage._normal._data, [_storage._normal._size]na
		</StringView>
		<Expand>
			<Item Name="_storage">_storage</Item>
		</Expand>
	</Type>

	<!-- ax::NameId_<*,*> -->
	<Type Name="ax::NameId_&lt; *, * &gt;">
		<DisplayString  Condition="_id == -1">NameId({_name})</DisplayString>
		<DisplayString                       >NameId({_name},{_id})</DisplayString>
	</Type>

</AutoVisualizer>