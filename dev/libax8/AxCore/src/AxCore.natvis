<?xml version="1.0" encoding="utf-8"?> 
<AutoVisualizer xmlns="http://schemas.microsoft.com/vstudio/debugger/natvis/2010"> 	

<!--
	Reference Document 
	https://msdn.microsoft.com/en-us/library/jj620914.aspx
	
	Expression[,<FormatSpecifier> ]
	https://msdn.microsoft.com/en-us/library/windows/hardware/dn936815(v=vs.85).aspx
-->
	<Type Name="ax::DebuggerNatvisHex::Low4">
		<DisplayString Condition="((c &amp; 0x0f) == 0x00)">0</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x01)">1</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x02)">2</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x03)">3</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x04)">4</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x05)">5</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x06)">6</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x07)">7</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x08)">8</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x09)">9</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0a)">A</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0b)">B</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0c)">C</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0d)">D</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0e)">E</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0f)">F</DisplayString>
	</Type>
 
	<Type Name="ax::DebuggerNatvisHex::High4">
		<DisplayString Condition="((c >> 4) == 0x00)">0</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x01)">1</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x02)">2</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x03)">3</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x04)">4</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x05)">5</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x06)">6</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x07)">7</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x08)">8</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x09)">9</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0a)">A</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0b)">B</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0c)">C</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0d)">D</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0e)">E</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0f)">F</DisplayString>
	</Type>

	<Type Name="ax::DebuggerNatvisHex::low4">
		<DisplayString Condition="((c &amp; 0x0f) == 0x00)">0</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x01)">1</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x02)">2</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x03)">3</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x04)">4</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x05)">5</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x06)">6</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x07)">7</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x08)">8</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x09)">9</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0a)">a</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0b)">b</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0c)">c</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0d)">d</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0e)">e</DisplayString>
		<DisplayString Condition="((c &amp; 0x0f) == 0x0f)">f</DisplayString>
	</Type>

	<Type Name="ax::DebuggerNatvisHex::high4">
		<DisplayString Condition="((c >> 4) == 0x00)">0</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x01)">1</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x02)">2</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x03)">3</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x04)">4</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x05)">5</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x06)">6</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x07)">7</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x08)">8</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x09)">9</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0a)">a</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0b)">b</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0c)">c</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0d)">d</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0e)">e</DisplayString>
		<DisplayString Condition="((c >> 4) == 0x0f)">f</DisplayString>
	</Type>

	<Type Name="ax::Uuid">
		<DisplayString>
			{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 0 )}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 0 )}{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 1 )}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 1 )}{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 2 )}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 2 )}{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 3 )}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 3 )}-{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 4 )}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 4 )}{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 5 )}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 5 )}-{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 6 )}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 6 )}{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 7 )}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 7 )}-{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 8 )}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 8 )}{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 9 )}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 9 )}-{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 10)}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 10)}{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 11)}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 11)}{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 12)}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 12)}{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 13)}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 13)}{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 14)}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 14)}{
			*(ax::DebuggerNatvisHex::high4*)((char*)this + 15)}{*(ax::DebuggerNatvisHex::low4*)((char*)this + 15)}
		</DisplayString>
		<Expand>
			<Item Name="first ">value.first,x</Item>
			<Item Name="second">value.second,x</Item>
		</Expand>
	</Type>

	<!-- ax::PtrBase<T> -->
	<Type Name="ax::PtrBase&lt;*&gt;">
		<DisplayString>{(void*)_p}</DisplayString>
		<Expand>
			<Item Name="_p">_p</Item>
		</Expand>
	</Type>

	<!-- ax::SPtr<T> -->
	<Type Name="ax::SPtr&lt;*&gt;">
		<DisplayString Condition="_p != nullptr">SPtr(ref={_p->m_SPtrRefCount}) {*_p}</DisplayString>
		<DisplayString>SPtr(NULL)</DisplayString>
		<Expand>
			<Item Name="_p">_p</Item>
			<Item Name="refCount">_p->m_SPtrRefCount</Item>
		</Expand>
	</Type>

	<!-- ax::AtomicInt_<*> -->
	<Type Name="ax::AtomicInt_&lt;*&gt;">
		<DisplayString>{_v}</DisplayString>
	</Type>

	<!-- ax::MutSpan<*> -->
	<Type Name="ax::MutSpan&lt;*&gt;">
		<DisplayString>Span size={_size}</DisplayString>
		<Expand> 
			<Item Name="_data">_data</Item>
			<Item Name="_size">_size</Item> 
			<ArrayItems> 
			  <Size>_size</Size> 
			  <ValuePointer>_data</ValuePointer> 
			</ArrayItems> 
		</Expand> 	
	</Type>
	
	<!-- ax::FixedArray<*,*> -->
	<Type Name="ax::FixedArray&lt;*,*&gt;">
		<DisplayString>size={kSize}</DisplayString>
		<Expand>
			<Item Name="kSize">kSize</Item>
			<ArrayItems>
				<Size>kSize</Size>
				<ValuePointer>_data</ValuePointer>
			</ArrayItems>
		</Expand>
	</Type>

	<!-- ax::IArayStorage<*>::Storage -->
	<Type Name="ax::IArrayStorage&lt;*&gt;::Storage">
		<DisplayString Condition=" _small.isSmall">size={_small.size } cap={_small.capacity} (extra={kSmallExtraCapacity})</DisplayString>
		<DisplayString Condition="!_small.isSmall">size={_normal.size} cap={_normal.capacity}</DisplayString>
		<Expand>
			<Item Name="data" Condition=" _small.isSmall">(ElementType*)&amp;((SmallStorage_Dummy&amp;)_small).data[0]</Item>
			<Item Name="data" Condition="!_small.isSmall">_normal.data</Item>

			<Item Name="size" Condition=" _small.isSmall"> _small.size</Item>
			<Item Name="size" Condition="!_small.isSmall">_normal.size</Item>

			<Item Name="capacity" Condition=" _small.isSmall"> _small.capacity</Item>
			<Item Name="capacity" Condition="!_small.isSmall">_normal.capacity</Item>

			<Item Name="kSmallExtraCapacity">kSmallExtraCapacity</Item>
			<Item Name="kSmallDataOffset"   >kSmallDataOffset</Item>
		</Expand>
	</Type>

	<!-- ax::IArray<*> -->
	<Type Name="ax::IArray&lt;*&gt;">
		<DisplayString>{_storage}</DisplayString>
		<Expand>
			<Synthetic Name="Elements">
				<DisplayString>{_storage}</DisplayString>
				<Expand>
					<ArrayItems Condition="_storage._small.isSmall">
						<Size>_storage._small.size</Size>
						<ValuePointer>(ElementType*)&amp;((SmallStorage_Dummy&amp;)_storage._small).data[0]</ValuePointer>
					</ArrayItems>

					<ArrayItems Condition="!_storage._small.isSmall">
						<Size>_storage._normal.size</Size>
						<ValuePointer>_storage._normal.data</ValuePointer>
					</ArrayItems>
				</Expand>
			</Synthetic>
		</Expand>
	</Type>

	<!-- ax::LinkedList<*> -->
	<Type Name="ax::LinkedList&lt;*&gt;">
		<DisplayString>size={_size}</DisplayString>
		<Expand>
			<LinkedListItems>
				<Size>_size</Size>
				<HeadPointer>_head</HeadPointer>
				<NextPointer>_listNode_next</NextPointer>
				<ValueNode>(_ListNodeOwner*)this</ValueNode>
			</LinkedListItems>
		</Expand>
	</Type>

	<!-- MutStrView_<*> -->
	<Type Name="ax::MutStrView_&lt;*&gt;">
		<DisplayString>{_data, [_size]na}</DisplayString>
		<StringView>_data, [_size]na</StringView>
		<Expand>
			<Item Name="size">_size</Item>
		</Expand>
	</Type>

	<!-- MutZStrView_<*> -->
	<Type Name="ax::MutZStrView_&lt;*&gt;">
		<DisplayString>{_data, [_size]na}</DisplayString>
		<StringView>_data, [_size]na</StringView>
		<Expand>
			<Item Name="size">_size</Item>
		</Expand>
	</Type>

	<!-- ax::IString_<*> -->
	<Type Name="ax::IString_&lt;*&gt;">
		<!-- small DisplayString -->
		<DisplayString Condition="_storage._small.isSmall &amp;&amp; kIsCharA">
			{((char*    )&amp;((SmallStorage_Dummy&amp;)_storage._small).data[0]),[_storage._small.size]na}
		</DisplayString>
		<DisplayString Condition="_storage._small.isSmall &amp;&amp; kIsCharW">
			{((wchar_t* )&amp;((SmallStorage_Dummy&amp;)_storage._small).data[0]), [_storage._small.size]na}
		</DisplayString>
		<DisplayString Condition="_storage._small.isSmall &amp;&amp; kIsChar8">
			{((char8_t* )&amp;((SmallStorage_Dummy&amp;)_storage._small).data[0]), [_storage._small.size]na}
		</DisplayString>
		<DisplayString Condition="_storage._small.isSmall &amp;&amp; kIsChar16">
			{((char16_t*)&amp;((SmallStorage_Dummy&amp;)_storage._small).data[0]), [_storage._small.size]na}
		</DisplayString>
		<DisplayString Condition="_storage._small.isSmall &amp;&amp; kIsChar32">
			{((char32_t*)&amp;((SmallStorage_Dummy&amp;)_storage._small).data[0]), [_storage._small.size]na}
		</DisplayString>
		
		<!-- normal DisplayString -->
		<DisplayString Condition="!_storage._small.isSmall &amp;&amp; kIsCharA">
			{_storage._normal.data, [_storage._normal.size]s8}
		</DisplayString>
		<DisplayString Condition="!_storage._small.isSmall &amp;&amp; kIsCharW">
			{_storage._normal.data, [_storage._normal.size]su}
		</DisplayString>
		<DisplayString Condition="!_storage._small.isSmall &amp;&amp; kIsChar8">
			{_storage._normal.data, [_storage._normal.size]s8}
		</DisplayString>
		<DisplayString Condition="!_storage._small.isSmall &amp;&amp; kIsChar16">
			{_storage._normal.data, [_storage._normal.size]su}
		</DisplayString>
		<DisplayString Condition="!_storage._small.isSmall &amp;&amp; kIsChar32">
			{_storage._normal.data, [_storage._normal.size]s32}
		</DisplayString>
		
		<!-- small StringView -->
		<StringView Condition="_storage._small.isSmall &amp;&amp; kIsCharA">
			((char*    )&amp;((SmallStorage_Dummy&amp;)_storage._small).data[0]), [_storage._small.size]na
		</StringView>
		<StringView Condition="_storage._small.isSmall &amp;&amp; kIsChar@">
			((wchar_t* )&amp;((SmallStorage_Dummy&amp;)_storage._small).data[0]), [_storage._small.size]na
		</StringView>
		<StringView Condition="_storage._small.isSmall &amp;&amp; kIsChar8">
			((char8_t* )&amp;((SmallStorage_Dummy&amp;)_storage._small).data[0]), [_storage._small.size]na
		</StringView>
		<StringView Condition="_storage._small.isSmall &amp;&amp; kIsChar16">
			((char16_t*)&amp;((SmallStorage_Dummy&amp;)_storage._small).data[0]), [_storage._small.size]na
		</StringView>
		<StringView Condition="_storage._small.isSmall &amp;&amp; kIsChar32">
			((char32_t*)&amp;((SmallStorage_Dummy&amp;)_storage._small).data[0]), [_storage._small.size]na
		</StringView>
		
		<!-- normal StringView -->
		<StringView  Condition="!_storage._small.isSmall">
			_storage._normal.data, [_storage._normal.size]na
		</StringView>

		<!-- Expand -->
		<Expand>
			<Item Name="_storage">_storage</Item>
		</Expand>
	</Type>

	<!-- ax::PersistString_<*> -->
	<Type Name="ax::PersistString_&lt; * &gt;">
		<DisplayString Condition="_data != nullptr">{_data->str}</DisplayString>
		<DisplayString></DisplayString>
	</Type>

	<!-- ax::NameId_<*,*> -->
	<Type Name="ax::NameId_&lt; *, * &gt;">
		<DisplayString  Condition="_id &lt; 0">[{_name}]</DisplayString>
		<DisplayString                        >[{_name}{_id}]</DisplayString>
	</Type>

</AutoVisualizer>